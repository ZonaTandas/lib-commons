# lib-commons no carga ficheros .env: estas variables las lee en runtime del
# entorno del servicio que la importa. Inventario completo de lo que consume.

# --- Observabilidad (src/obs) ---
# Nivel mínimo de log del slog JSON instalado por obs.Init: debug|info|warn|error.
OBS_LOG_LEVEL=info
# Bytes máximos capturados de cada cuerpo (petición y respuesta) en la línea http_request.
OBS_MAX_BODY_BYTES=8192
# Política de captura de cuerpos: writes+errors (default) | errors | off.
OBS_CAPTURE_BODIES=writes+errors
# CSV de rutas que solo se loguean si fallan (prefijo, o sufijo si empieza por "*").
OBS_SAMPLE_PATHS=/sse,*/availability

# --- Verificación de origen interno (src/obs/internalauth.go) ---
# Secreto compartido de X-Internal-Auth. SENSIBLE: en k8s va en el Secret del
# servicio, jamás en claro en manifiestos ni en este fichero.
INTERNAL_SHARED_SECRET=cambia-esto
# "true" activa el enforce (403 si falta/está mal la cabecera); cualquier otro valor = log-only.
INTERNAL_AUTH_ENFORCE=false
# CSV de prefijos de ruta exentos (webhooks, contenido público del navegador).
INTERNAL_AUTH_EXEMPT_PATHS=/contents,/webhooks/stripe

# --- Métricas (src/obs/obsmetrics) ---
# Bearer exigido por obsmetrics.TokenHandler en /metrics. Vacío = cerrado (fail-closed).
AUTH_SERVICE_TOKEN=cambia-esto
